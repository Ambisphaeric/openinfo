{
  "$id": "SessionTitling",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "workspaceId",
    "sessionId",
    "title",
    "source",
    "createdAt",
    "schemaVersion"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "description": "the human-meaningful episode name — never a raw id",
      "type": "string"
    },
    "source": {
      "description": "derived (from an orientation pass) or user (a sovereign rename)",
      "anyOf": [
        {
          "const": "derived",
          "type": "string"
        },
        {
          "const": "user",
          "type": "string"
        }
      ]
    },
    "provenance": {
      "$id": "TitlingProvenance",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "annotationId",
        "templateId",
        "endpoint",
        "classifiedAt",
        "nature",
        "direction",
        "topics"
      ],
      "properties": {
        "annotationId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "templateId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "endpoint": {
          "description": "the fabric endpoint that classified (never a secret value)",
          "type": "string"
        },
        "model": {
          "description": "the model that answered, when the endpoint names one",
          "type": "string"
        },
        "classifiedAt": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "nature": {
          "description": "the orientation nature the title drew from (evidence, not fabricated)",
          "type": "string"
        },
        "direction": {
          "description": "the orientation direction the title drew from",
          "type": "string"
        },
        "topics": {
          "description": "the orientation topics the title drew from",
          "type": "array",
          "items": {
            "minLength": 1,
            "type": "string"
          }
        }
      }
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "schemaVersion": {
      "minimum": 1,
      "type": "integer"
    }
  }
}
