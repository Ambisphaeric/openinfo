{
  "$id": "Bundle",
  "additionalProperties": false,
  "description": "an app bundle — references to the organs of one app (faces, workflow, templates, flags, chat assembly), all versioned documents",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "faces"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "minimum": 1,
      "description": "store-stamped, monotonic; every prior version is kept",
      "type": "integer"
    },
    "description": {
      "type": "string"
    },
    "faces": {
      "minItems": 1,
      "description": "the app’s faces (surface refs); hud first by convention, support may repeat",
      "type": "array",
      "items": {
        "$id": "BundleFace",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "kind",
          "surfaceRef"
        ],
        "properties": {
          "kind": {
            "$id": "BundleFaceKind",
            "description": "append-only closed union of app-face roles (hud | chat | support)",
            "anyOf": [
              {
                "const": "hud",
                "type": "string"
              },
              {
                "const": "chat",
                "type": "string"
              },
              {
                "const": "support",
                "type": "string"
              }
            ]
          },
          "surfaceRef": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "title": {
            "minLength": 1,
            "description": "display override; absent ⇒ the mapped surface’s own name (the window factory titles it)",
            "type": "string"
          }
        }
      }
    },
    "workflowRef": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "templateRefs": {
      "description": "PromptTemplate document ids this app uses — references, never inlined bodies",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "flags": {
      "description": "flag-config OVERLAY: flag key → desired enabled state; a declared posture (injection is a later slice), never applied here",
      "type": "object",
      "patternProperties": {
        "^(.*)$": {
          "type": "boolean"
        }
      }
    },
    "chat": {
      "$id": "ChatContextAssembly",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "sources"
      ],
      "properties": {
        "sources": {
          "minItems": 1,
          "description": "ordered chat context sources with honest budgets — assembly is data, not code",
          "type": "array",
          "items": {
            "$id": "ChatContextSource",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "$id": "ChatContextSourceKind",
                "description": "append-only closed union of the nine chat context sources",
                "anyOf": [
                  {
                    "const": "bundle-prompt",
                    "type": "string"
                  },
                  {
                    "const": "active-preset",
                    "type": "string"
                  },
                  {
                    "const": "transcript-window",
                    "type": "string"
                  },
                  {
                    "const": "insights",
                    "type": "string"
                  },
                  {
                    "const": "relevant-entities",
                    "type": "string"
                  },
                  {
                    "const": "attached-docs",
                    "type": "string"
                  },
                  {
                    "const": "recent-turns",
                    "type": "string"
                  },
                  {
                    "const": "screen",
                    "type": "string"
                  },
                  {
                    "const": "packets",
                    "type": "string"
                  }
                ]
              },
              "limit": {
                "minimum": 0,
                "description": "max items/turns this source contributes; absent ⇒ engine default",
                "type": "integer"
              },
              "windowChars": {
                "minimum": 0,
                "description": "rolling character window for this source; absent ⇒ engine default",
                "type": "integer"
              },
              "tokenBudget": {
                "minimum": 0,
                "description": "estimated-token budget (chars/4) this source may occupy; absent ⇒ engine default",
                "type": "integer"
              }
            }
          }
        }
      }
    }
  }
}
