{
  "$id": "Summary",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "workspaceId",
    "level",
    "windowStart",
    "windowEnd",
    "children",
    "bound",
    "proposal",
    "confidence",
    "provenance",
    "revision",
    "schemaVersion",
    "createdAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "level": {
      "$id": "SummaryLevel",
      "description": "the summary timescale, finest (rolling) to coarsest (project)",
      "anyOf": [
        {
          "const": "rolling",
          "type": "string"
        },
        {
          "const": "episode",
          "type": "string"
        },
        {
          "const": "five-minute",
          "type": "string"
        },
        {
          "const": "session",
          "type": "string"
        },
        {
          "const": "project",
          "type": "string"
        }
      ]
    },
    "windowStart": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "windowEnd": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "children": {
      "description": "refs to bounded lower-level inputs + selective evidence — never copied content",
      "type": "array",
      "items": {
        "$id": "SummaryChild",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "record",
          "id",
          "at",
          "role"
        ],
        "properties": {
          "record": {
            "description": "which record table the id names — the closed set of summarizable inputs and evidence",
            "anyOf": [
              {
                "const": "summary",
                "type": "string"
              },
              {
                "const": "context-packet",
                "type": "string"
              },
              {
                "const": "distillate",
                "type": "string"
              },
              {
                "const": "moment",
                "type": "string"
              },
              {
                "const": "stt-segment",
                "type": "string"
              },
              {
                "const": "ocr-result",
                "type": "string"
              }
            ]
          },
          "id": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "at": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "role": {
            "description": "`child` = a bounded lower-level input this summary is derived FROM; `evidence` = selectively-retrieved corroborating source",
            "anyOf": [
              {
                "const": "child",
                "type": "string"
              },
              {
                "const": "evidence",
                "type": "string"
              }
            ]
          },
          "level": {
            "$id": "SummaryLevel",
            "description": "the summary timescale, finest (rolling) to coarsest (project)",
            "anyOf": [
              {
                "const": "rolling",
                "type": "string"
              },
              {
                "const": "episode",
                "type": "string"
              },
              {
                "const": "five-minute",
                "type": "string"
              },
              {
                "const": "session",
                "type": "string"
              },
              {
                "const": "project",
                "type": "string"
              }
            ]
          }
        }
      }
    },
    "bound": {
      "$id": "SummaryInputBound",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "childrenAvailable",
        "childrenConsumed",
        "evidenceAvailable",
        "evidenceConsumed"
      ],
      "properties": {
        "childrenAvailable": {
          "minimum": 0,
          "description": "lower-level inputs that existed in the window",
          "type": "integer"
        },
        "childrenConsumed": {
          "minimum": 0,
          "description": "lower-level inputs actually fed to the summarizer (<= maxChildren)",
          "type": "integer"
        },
        "evidenceAvailable": {
          "minimum": 0,
          "description": "candidate evidence records in the window",
          "type": "integer"
        },
        "evidenceConsumed": {
          "minimum": 0,
          "description": "evidence records actually fed (<= maxEvidence)",
          "type": "integer"
        }
      }
    },
    "text": {
      "description": "the summary prose (model-PROPOSED, or human-authored on a `source:user` correction); ABSENT ⇒ degraded (see `degraded`)",
      "type": "string"
    },
    "proposal": {
      "description": "#189: true ⇒ model PROPOSAL, never canonical truth; false ⇒ a sovereign user correction",
      "type": "boolean"
    },
    "source": {
      "description": "model (deterministic-skeleton + model prose proposal) · user (sovereign human correction, outranks model); ABSENT ⇒ model (pre-#246 rows)",
      "anyOf": [
        {
          "const": "model",
          "type": "string"
        },
        {
          "const": "user",
          "type": "string"
        }
      ]
    },
    "correction": {
      "$id": "SummaryCorrection",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "at"
      ],
      "properties": {
        "at": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "by": {
          "description": "who made the correction — the user (never a machine)",
          "type": "string"
        }
      }
    },
    "corrects": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "degraded": {
      "additionalProperties": false,
      "description": "present ⇒ no prose (honest unavailable state); absent ⇒ `text` is present",
      "type": "object",
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "minLength": 1,
          "description": "why no prose was produced — e.g. no summarizer endpoint, invoke failed",
          "type": "string"
        }
      }
    },
    "confidence": {
      "minimum": 0,
      "maximum": 1,
      "type": "number"
    },
    "provenance": {
      "$id": "SummaryProvenance",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "builder",
        "windowMs",
        "templateId"
      ],
      "properties": {
        "builder": {
          "const": "bounded-hierarchical-summary",
          "type": "string"
        },
        "windowMs": {
          "minimum": 0,
          "description": "the interval bucket size this level assembled with (0 for whole-session bucketing)",
          "type": "integer"
        },
        "childLevel": {
          "$id": "SummaryLevel",
          "description": "the summary timescale, finest (rolling) to coarsest (project)",
          "anyOf": [
            {
              "const": "rolling",
              "type": "string"
            },
            {
              "const": "episode",
              "type": "string"
            },
            {
              "const": "five-minute",
              "type": "string"
            },
            {
              "const": "session",
              "type": "string"
            },
            {
              "const": "project",
              "type": "string"
            }
          ]
        },
        "templateId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "templateScope": {
          "description": "which config scope resolved this level’s template (#177 slice 2 per-workflow/app scoping) — the which-scope-won audit; absent ⇒ workspace-global",
          "anyOf": [
            {
              "const": "workspace",
              "type": "string"
            },
            {
              "const": "workflow",
              "type": "string"
            },
            {
              "const": "app",
              "type": "string"
            }
          ]
        },
        "slot": {
          "description": "fabric capability slot",
          "anyOf": [
            {
              "const": "stt",
              "type": "string"
            },
            {
              "const": "tts",
              "type": "string"
            },
            {
              "const": "llm",
              "type": "string"
            },
            {
              "const": "vlm",
              "type": "string"
            },
            {
              "const": "ocr",
              "type": "string"
            },
            {
              "const": "embed",
              "type": "string"
            }
          ]
        },
        "endpoint": {
          "minLength": 1,
          "description": "fabric endpoint name that produced the prose",
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "usage": {
          "$id": "InvokeUsage",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "estimated"
          ],
          "properties": {
            "promptTokens": {
              "minimum": 0,
              "description": "input tokens (prompt), when known",
              "type": "integer"
            },
            "completionTokens": {
              "minimum": 0,
              "description": "output tokens (generated), when known",
              "type": "integer"
            },
            "totalTokens": {
              "minimum": 0,
              "description": "prompt + completion, when the server reports it or both halves are known",
              "type": "integer"
            },
            "estimated": {
              "description": "true ⇒ counts are chars/4 estimates (the server reported no usage); false ⇒ measured from the API",
              "type": "boolean"
            },
            "durationMs": {
              "minimum": 0,
              "description": "wall-clock duration of the invoke in ms",
              "type": "integer"
            }
          }
        },
        "egress": {
          "$id": "EgressDecision",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "reach",
            "allowed",
            "decidedBy",
            "reason"
          ],
          "properties": {
            "reach": {
              "$id": "EgressReach",
              "description": "layer 1 compatibility bucket: local-network (device loopback/managed or private LAN) vs hosted/public egress; use EgressDecision.destination for physical boundary truth",
              "anyOf": [
                {
                  "const": "local",
                  "type": "string"
                },
                {
                  "const": "egress",
                  "type": "string"
                }
              ]
            },
            "allowed": {
              "description": "did the layered content-side policy permit hosted/public egress for this content?",
              "type": "boolean"
            },
            "decidedBy": {
              "$id": "EgressLayer",
              "description": "which of the four layers decided (or `default` = no denial, `endpoint` = destination-classification decided)",
              "anyOf": [
                {
                  "const": "endpoint",
                  "type": "string"
                },
                {
                  "const": "prompt",
                  "type": "string"
                },
                {
                  "const": "mode",
                  "type": "string"
                },
                {
                  "const": "workspace",
                  "type": "string"
                },
                {
                  "const": "content-class",
                  "type": "string"
                },
                {
                  "const": "default",
                  "type": "string"
                }
              ]
            },
            "reason": {
              "minLength": 1,
              "description": "one-line, human-readable why — safe to surface (no url/secret)",
              "type": "string"
            },
            "destination": {
              "$id": "EgressDestination",
              "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
              "anyOf": [
                {
                  "const": "device-local",
                  "type": "string"
                },
                {
                  "const": "lan-local",
                  "type": "string"
                },
                {
                  "const": "hosted-public",
                  "type": "string"
                }
              ]
            },
            "rawFrameTrust": {
              "description": "present only when raw screen bytes crossed to a LAN-local HTTP endpoint under that endpoint’s explicit trustRawFrames opt-in",
              "const": "explicit",
              "type": "string"
            }
          }
        },
        "guard": {
          "$id": "GuardVerdict",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "outcome",
            "behavior",
            "guarded",
            "maskedSpanCount",
            "reason"
          ],
          "properties": {
            "outcome": {
              "description": "clean = guard ran, nothing flagged; redacted = flagged spans masked, hop proceeded; held = hop suspended (strict, or fail-closed empty slot); unguarded = no guard active, proceeded under explicit acknowledgment",
              "anyOf": [
                {
                  "const": "clean",
                  "type": "string"
                },
                {
                  "const": "redacted",
                  "type": "string"
                },
                {
                  "const": "held",
                  "type": "string"
                },
                {
                  "const": "unguarded",
                  "type": "string"
                }
              ]
            },
            "behavior": {
              "$id": "GuardBehavior",
              "description": "redact-and-continue (default, mask spans + proceed) | hold-and-surface (strict, suspend the hop)",
              "anyOf": [
                {
                  "const": "redact-and-continue",
                  "type": "string"
                },
                {
                  "const": "hold-and-surface",
                  "type": "string"
                }
              ]
            },
            "guarded": {
              "description": "true ⇒ a guard endpoint classified the content; false ⇒ no guard ran (acknowledged-unguarded or fail-closed-empty)",
              "type": "boolean"
            },
            "maskedSpanCount": {
              "minimum": 0,
              "description": "how many spans were masked (0 for clean/held/unguarded)",
              "type": "integer"
            },
            "spans": {
              "description": "span descriptors (kind/start/length) — never the raw value; present when spans were flagged",
              "type": "array",
              "items": {
                "$id": "GuardSpan",
                "additionalProperties": false,
                "type": "object",
                "required": [
                  "kind",
                  "start",
                  "length"
                ],
                "properties": {
                  "kind": {
                    "minLength": 1,
                    "description": "the classifier label for this span (e.g. card-number) — a category, never the value",
                    "type": "string"
                  },
                  "start": {
                    "minimum": 0,
                    "description": "character offset of the span in the outbound text",
                    "type": "integer"
                  },
                  "length": {
                    "minimum": 1,
                    "description": "character length of the masked span (extent only — never the value)",
                    "type": "integer"
                  }
                }
              }
            },
            "guardEndpoint": {
              "description": "the guard endpoint NAME that classified — never a url/secret; absent when no guard ran",
              "type": "string"
            },
            "classifierDestination": {
              "$id": "EgressDestination",
              "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
              "anyOf": [
                {
                  "const": "device-local",
                  "type": "string"
                },
                {
                  "const": "lan-local",
                  "type": "string"
                },
                {
                  "const": "hosted-public",
                  "type": "string"
                }
              ]
            },
            "reason": {
              "minLength": 1,
              "description": "one-line, human-readable why — safe to surface (no raw value)",
              "type": "string"
            }
          }
        }
      }
    },
    "revision": {
      "minimum": 1,
      "description": "position in this interval’s append-only supersession chain",
      "type": "integer"
    },
    "supersedes": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "schemaVersion": {
      "minimum": 1,
      "type": "integer"
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
