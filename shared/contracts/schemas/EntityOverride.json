{
  "$id": "EntityOverride",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "at"
  ],
  "properties": {
    "at": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "by": {
      "description": "who made the correction — the user",
      "type": "string"
    },
    "pinnedName": {
      "description": "surface form pinned to this entity — future mentions of it resolve here",
      "type": "string"
    },
    "rejectedRivalId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "rejectedRivalName": {
      "type": "string"
    },
    "note": {
      "description": "the correction's rationale (never a secret value)",
      "type": "string"
    }
  }
}
