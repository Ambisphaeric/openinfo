{
  "$id": "OcrResult",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "sessionId",
    "workspaceId",
    "sourceChunks",
    "text",
    "provenance",
    "schemaVersion",
    "createdAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sourceChunks": {
      "description": "screen CaptureChunk ids understood in this pass",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "spanId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "text": {
      "description": "the recognized text — flattened join of blocks (ocr) or the VLM prose",
      "type": "string"
    },
    "blocks": {
      "description": "per-region boxes+confidence; present for a region-aware (ocr) runtime, absent for a vlm",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "description": "the recognized text of this region",
            "type": "string"
          },
          "confidence": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "region": {
            "additionalProperties": false,
            "description": "bounding box in the frame pixel coordinate space",
            "type": "object",
            "required": [
              "x",
              "y",
              "width",
              "height"
            ],
            "properties": {
              "x": {
                "minimum": 0,
                "type": "integer"
              },
              "y": {
                "minimum": 0,
                "type": "integer"
              },
              "width": {
                "minimum": 1,
                "type": "integer"
              },
              "height": {
                "minimum": 1,
                "type": "integer"
              }
            }
          }
        }
      }
    },
    "provenance": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slot",
        "endpoint"
      ],
      "properties": {
        "slot": {
          "description": "which capability slot produced this — a subset of SlotName",
          "anyOf": [
            {
              "const": "ocr",
              "type": "string"
            },
            {
              "const": "vlm",
              "type": "string"
            }
          ]
        },
        "endpoint": {
          "minLength": 1,
          "description": "fabric endpoint name that produced this",
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "usage": {
          "$id": "InvokeUsage",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "estimated"
          ],
          "properties": {
            "promptTokens": {
              "minimum": 0,
              "description": "input tokens (prompt), when known",
              "type": "integer"
            },
            "completionTokens": {
              "minimum": 0,
              "description": "output tokens (generated), when known",
              "type": "integer"
            },
            "totalTokens": {
              "minimum": 0,
              "description": "prompt + completion, when the server reports it or both halves are known",
              "type": "integer"
            },
            "estimated": {
              "description": "true ⇒ counts are chars/4 estimates (the server reported no usage); false ⇒ measured from the API",
              "type": "boolean"
            },
            "durationMs": {
              "minimum": 0,
              "description": "wall-clock duration of the invoke in ms",
              "type": "integer"
            }
          }
        },
        "egress": {
          "$id": "EgressDecision",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "reach",
            "allowed",
            "decidedBy",
            "reason"
          ],
          "properties": {
            "reach": {
              "$id": "EgressReach",
              "description": "layer 1 compatibility bucket: local-network (device loopback/managed or private LAN) vs hosted/public egress; use EgressDecision.destination for physical boundary truth",
              "anyOf": [
                {
                  "const": "local",
                  "type": "string"
                },
                {
                  "const": "egress",
                  "type": "string"
                }
              ]
            },
            "allowed": {
              "description": "did the layered content-side policy permit hosted/public egress for this content?",
              "type": "boolean"
            },
            "decidedBy": {
              "$id": "EgressLayer",
              "description": "which of the four layers decided (or `default` = no denial, `endpoint` = destination-classification decided)",
              "anyOf": [
                {
                  "const": "endpoint",
                  "type": "string"
                },
                {
                  "const": "prompt",
                  "type": "string"
                },
                {
                  "const": "mode",
                  "type": "string"
                },
                {
                  "const": "workspace",
                  "type": "string"
                },
                {
                  "const": "content-class",
                  "type": "string"
                },
                {
                  "const": "default",
                  "type": "string"
                }
              ]
            },
            "reason": {
              "minLength": 1,
              "description": "one-line, human-readable why — safe to surface (no url/secret)",
              "type": "string"
            },
            "destination": {
              "$id": "EgressDestination",
              "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
              "anyOf": [
                {
                  "const": "device-local",
                  "type": "string"
                },
                {
                  "const": "lan-local",
                  "type": "string"
                },
                {
                  "const": "hosted-public",
                  "type": "string"
                }
              ]
            },
            "rawFrameTrust": {
              "description": "present only when raw screen bytes crossed to a LAN-local HTTP endpoint under that endpoint’s explicit trustRawFrames opt-in",
              "const": "explicit",
              "type": "string"
            }
          }
        }
      }
    },
    "schemaVersion": {
      "minimum": 1,
      "type": "integer"
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "capturedAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
