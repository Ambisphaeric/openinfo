{
  "$id": "Distillate",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "sessionId",
    "workspaceId",
    "windowStart",
    "windowEnd",
    "sourceChunks",
    "text",
    "voice",
    "provenance",
    "schemaVersion",
    "createdAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "windowStart": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "windowEnd": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "sourceChunks": {
      "description": "capture chunk ids merged into this window",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "text": {
      "description": "the distilled summary text",
      "type": "string"
    },
    "voice": {
      "additionalProperties": false,
      "description": "the resolved voice vector this pass ran with",
      "type": "object",
      "required": [
        "scope",
        "dials"
      ],
      "properties": {
        "registerId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "scope": {
          "description": "which binding scope won resolution",
          "anyOf": [
            {
              "const": "global",
              "type": "string"
            },
            {
              "const": "mode",
              "type": "string"
            },
            {
              "const": "workspace",
              "type": "string"
            },
            {
              "const": "session",
              "type": "string"
            }
          ]
        },
        "dials": {
          "$id": "Dials",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "tone",
            "warmth",
            "wit",
            "charm",
            "specificity",
            "brevity"
          ],
          "properties": {
            "tone": {
              "minimum": 0,
              "maximum": 10,
              "type": "integer"
            },
            "warmth": {
              "minimum": 0,
              "maximum": 10,
              "type": "integer"
            },
            "wit": {
              "minimum": 0,
              "maximum": 10,
              "type": "integer"
            },
            "charm": {
              "minimum": 0,
              "maximum": 10,
              "type": "integer"
            },
            "specificity": {
              "minimum": 0,
              "maximum": 10,
              "type": "integer"
            },
            "brevity": {
              "minimum": 0,
              "maximum": 10,
              "type": "integer"
            }
          }
        }
      }
    },
    "provenance": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "slot",
        "endpoint"
      ],
      "properties": {
        "slot": {
          "description": "fabric capability slot",
          "anyOf": [
            {
              "const": "stt",
              "type": "string"
            },
            {
              "const": "tts",
              "type": "string"
            },
            {
              "const": "llm",
              "type": "string"
            },
            {
              "const": "vlm",
              "type": "string"
            },
            {
              "const": "ocr",
              "type": "string"
            },
            {
              "const": "embed",
              "type": "string"
            }
          ]
        },
        "endpoint": {
          "minLength": 1,
          "description": "fabric endpoint name that produced this",
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "schemaVersion": {
      "minimum": 1,
      "type": "integer"
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
