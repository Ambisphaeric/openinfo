{
  "$id": "TeachSignal",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "kind",
    "correctedAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "kind": {
      "anyOf": [
        {
          "const": "reroute",
          "type": "string"
        },
        {
          "const": "alias-confirm",
          "type": "string"
        },
        {
          "const": "alias-reject",
          "type": "string"
        },
        {
          "const": "rename",
          "type": "string"
        },
        {
          "const": "disambiguate",
          "type": "string"
        },
        {
          "const": "dismiss",
          "type": "string"
        }
      ]
    },
    "fromWorkspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "toWorkspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "evidence": {
      "description": "reroute only: the router's original attribution trail at correction time (window/repo/calendar + the manual reroute marker)",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "kind",
          "detail",
          "weight"
        ],
        "properties": {
          "kind": {
            "anyOf": [
              {
                "const": "calendar",
                "type": "string"
              },
              {
                "const": "window",
                "type": "string"
              },
              {
                "const": "repo",
                "type": "string"
              },
              {
                "const": "voice",
                "type": "string"
              },
              {
                "const": "manual",
                "type": "string"
              }
            ]
          },
          "detail": {
            "type": "string"
          },
          "weight": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          }
        }
      }
    },
    "entity": {
      "$id": "EntityCorrectionSignal",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "workspaceId",
        "entityId",
        "heard"
      ],
      "properties": {
        "workspaceId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "entityId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "heard": {
          "minLength": 1,
          "description": "the heard surface form the verdict settles",
          "type": "string"
        },
        "rivalId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "rivalName": {
          "type": "string"
        },
        "pinnedEntityId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        }
      }
    },
    "correctedAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
