{
  "$id": "FieldValue",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "fieldId",
    "workspaceId",
    "label",
    "value",
    "state",
    "provenance",
    "updatedAt",
    "schemaVersion"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "fieldId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "label": {
      "minLength": 1,
      "description": "the display name of the field (the prompt document name)",
      "type": "string"
    },
    "value": {
      "description": "the model output text for this field — the current value",
      "type": "string"
    },
    "state": {
      "description": "field micro-state / judge tier (#66) — a fast result is `provisional`; a judge review (#62) moves it to `confirmed` (value stands), `corrected` (value overruled in place), or `flagged` (questionable). Document-configurable vocab per surface; never fabricated.",
      "type": "string"
    },
    "provenance": {
      "$id": "FieldValueProvenance",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "templateId",
        "slot",
        "endpoint"
      ],
      "properties": {
        "templateId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "slot": {
          "description": "fabric capability slot",
          "anyOf": [
            {
              "const": "stt",
              "type": "string"
            },
            {
              "const": "tts",
              "type": "string"
            },
            {
              "const": "llm",
              "type": "string"
            },
            {
              "const": "vlm",
              "type": "string"
            },
            {
              "const": "ocr",
              "type": "string"
            },
            {
              "const": "embed",
              "type": "string"
            }
          ]
        },
        "endpoint": {
          "description": "the fabric endpoint name that produced the value (never a secret value)",
          "type": "string"
        },
        "model": {
          "description": "the model that answered, when the endpoint names one",
          "type": "string"
        },
        "windowStart": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "windowEnd": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "judge": {
          "$id": "JudgeReview",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "templateId",
            "endpoint",
            "verdict",
            "judgedAt"
          ],
          "properties": {
            "templateId": {
              "minLength": 1,
              "description": "opaque identifier",
              "type": "string"
            },
            "endpoint": {
              "description": "the fabric endpoint name that judged (never a secret value)",
              "type": "string"
            },
            "model": {
              "description": "the judge model that answered, when the endpoint names one",
              "type": "string"
            },
            "verdict": {
              "description": "confirm: value stands; correct: value overruled in place (see priorValue); flag: questionable/too thin to judge",
              "anyOf": [
                {
                  "const": "confirm",
                  "type": "string"
                },
                {
                  "const": "correct",
                  "type": "string"
                },
                {
                  "const": "flag",
                  "type": "string"
                }
              ]
            },
            "priorValue": {
              "description": "the fast value the judge overruled — present on a `correct`, so \"what changed\" is inspectable",
              "type": "string"
            },
            "priorState": {
              "description": "the field state the review moved off of (e.g. provisional)",
              "type": "string"
            },
            "note": {
              "description": "the judge's rationale — the flag reason, or why a value was corrected",
              "type": "string"
            },
            "judgedAt": {
              "format": "date-time",
              "description": "ISO-8601 timestamp",
              "type": "string"
            }
          }
        }
      }
    },
    "updatedAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "schemaVersion": {
      "minimum": 1,
      "type": "integer"
    }
  }
}
