{
  "$id": "TodoList",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "sessionId",
    "workspaceId",
    "items"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "minimum": 1,
      "description": "store-stamped, monotonic; every prior version is kept",
      "type": "integer"
    },
    "description": {
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "items": {
      "default": [],
      "type": "array",
      "items": {
        "$id": "TodoItem",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "text",
          "createdAt"
        ],
        "properties": {
          "id": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "text": {
            "minLength": 1,
            "description": "the follow-up, as a short imperative line",
            "type": "string"
          },
          "done": {
            "description": "user checked it off; extraction never sets this",
            "type": "boolean"
          },
          "provenance": {
            "$id": "TodoProvenance",
            "additionalProperties": false,
            "type": "object",
            "properties": {
              "sessionId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "distillateId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "momentId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              }
            }
          },
          "createdAt": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          }
        }
      }
    }
  }
}
