{
  "$id": "PinChunk",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "pinId",
    "workspaceId",
    "ordinal",
    "text",
    "createdAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "pinId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "ordinal": {
      "minimum": 0,
      "description": "chunk sequence within the pin (0-based, stable)",
      "type": "integer"
    },
    "page": {
      "minimum": 1,
      "description": "1-based source page anchor; absent for pageless sources (url/plaintext)",
      "type": "integer"
    },
    "text": {
      "minLength": 1,
      "type": "string"
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
