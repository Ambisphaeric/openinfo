{
  "$id": "HintCandidate",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "workspaceId",
    "pattern",
    "supportCount",
    "sampleSessionIds"
  ],
  "properties": {
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "pattern": {
      "$id": "AttributionPattern",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "field",
        "weight"
      ],
      "properties": {
        "field": {
          "anyOf": [
            {
              "const": "repoPath",
              "type": "string"
            },
            {
              "const": "windowTitle",
              "type": "string"
            },
            {
              "const": "app",
              "type": "string"
            },
            {
              "const": "eventTitle",
              "type": "string"
            },
            {
              "const": "attendee",
              "type": "string"
            }
          ]
        },
        "contains": {
          "minLength": 1,
          "description": "case-insensitive substring match against the field",
          "type": "string"
        },
        "prefix": {
          "minLength": 1,
          "description": "case-insensitive prefix match against the field",
          "type": "string"
        },
        "weight": {
          "minimum": 0,
          "maximum": 1,
          "type": "number"
        }
      }
    },
    "supportCount": {
      "minimum": 1,
      "description": "distinct reroutes supporting this exact (field, contains)",
      "type": "integer"
    },
    "sampleSessionIds": {
      "description": "the reroutes behind the candidate — always traceable to its corrections",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    }
  }
}
