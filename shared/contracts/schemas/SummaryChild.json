{
  "$id": "SummaryChild",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "record",
    "id",
    "at",
    "role"
  ],
  "properties": {
    "record": {
      "description": "which record table the id names — the closed set of summarizable inputs and evidence",
      "anyOf": [
        {
          "const": "summary",
          "type": "string"
        },
        {
          "const": "context-packet",
          "type": "string"
        },
        {
          "const": "distillate",
          "type": "string"
        },
        {
          "const": "moment",
          "type": "string"
        },
        {
          "const": "stt-segment",
          "type": "string"
        },
        {
          "const": "ocr-result",
          "type": "string"
        }
      ]
    },
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "at": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "role": {
      "description": "`child` = a bounded lower-level input this summary is derived FROM; `evidence` = selectively-retrieved corroborating source",
      "anyOf": [
        {
          "const": "child",
          "type": "string"
        },
        {
          "const": "evidence",
          "type": "string"
        }
      ]
    },
    "level": {
      "$id": "SummaryLevel",
      "description": "the summary timescale, finest (rolling) to coarsest (project)",
      "anyOf": [
        {
          "const": "rolling",
          "type": "string"
        },
        {
          "const": "episode",
          "type": "string"
        },
        {
          "const": "five-minute",
          "type": "string"
        },
        {
          "const": "session",
          "type": "string"
        },
        {
          "const": "project",
          "type": "string"
        }
      ]
    }
  }
}
