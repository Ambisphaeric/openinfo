{
  "$id": "Surface",
  "additionalProperties": false,
  "description": "workspaceId (#99, append-only, optional): an APP INSTANCE is this surface bound to a workspace silo. When present it becomes the DEFAULT workspace for this surface’s block queries (POST /query?surface=<id>) — an explicit per-block params.workspace still wins. Absent ⇒ unchanged behavior (queries default to ‘default’). Same template instantiated for N repos = N surfaces, each naming its own workspace.",
  "type": "object",
  "required": [
    "id",
    "name",
    "context",
    "stack",
    "version"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "context": {
      "minLength": 1,
      "description": "meeting | deep-work | idle | any | user-defined",
      "type": "string"
    },
    "stack": {
      "minItems": 1,
      "type": "array",
      "items": {
        "$id": "Block",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "block"
        ],
        "properties": {
          "block": {
            "$id": "BlockTypeName",
            "anyOf": [
              {
                "const": "now",
                "type": "string"
              },
              {
                "const": "moments",
                "type": "string"
              },
              {
                "const": "relevant-now",
                "type": "string"
              },
              {
                "const": "ledger",
                "type": "string"
              },
              {
                "const": "pinned-doc",
                "type": "string"
              },
              {
                "const": "hint",
                "type": "string"
              },
              {
                "const": "ask",
                "type": "string"
              },
              {
                "const": "todos",
                "type": "string"
              },
              {
                "const": "drafts",
                "type": "string"
              },
              {
                "const": "teach",
                "type": "string"
              },
              {
                "const": "distillates",
                "type": "string"
              },
              {
                "const": "summaries",
                "type": "string"
              },
              {
                "const": "fields",
                "type": "string"
              },
              {
                "const": "queue",
                "type": "string"
              },
              {
                "const": "transcript-inspector",
                "type": "string"
              },
              {
                "const": "sense-gates",
                "type": "string"
              },
              {
                "const": "input",
                "type": "string"
              },
              {
                "const": "custom",
                "type": "string"
              },
              {
                "const": "sense-lanes",
                "type": "string"
              },
              {
                "const": "session-control",
                "type": "string"
              },
              {
                "const": "sessions",
                "type": "string"
              }
            ]
          },
          "id": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "query": {
            "$id": "BlockQuery",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "source",
              "params"
            ],
            "properties": {
              "source": {
                "anyOf": [
                  {
                    "const": "relevant-now",
                    "type": "string"
                  },
                  {
                    "const": "moments",
                    "type": "string"
                  },
                  {
                    "const": "ledger",
                    "type": "string"
                  },
                  {
                    "const": "sessions",
                    "type": "string"
                  },
                  {
                    "const": "pins",
                    "type": "string"
                  },
                  {
                    "const": "entities",
                    "type": "string"
                  },
                  {
                    "const": "todos",
                    "type": "string"
                  },
                  {
                    "const": "drafts",
                    "type": "string"
                  },
                  {
                    "const": "teach",
                    "type": "string"
                  },
                  {
                    "const": "distillates",
                    "type": "string"
                  },
                  {
                    "const": "summaries",
                    "type": "string"
                  },
                  {
                    "const": "fields",
                    "type": "string"
                  },
                  {
                    "const": "queue",
                    "type": "string"
                  },
                  {
                    "const": "transcript",
                    "type": "string"
                  },
                  {
                    "const": "senses",
                    "type": "string"
                  },
                  {
                    "const": "live-senses",
                    "type": "string"
                  }
                ]
              },
              "params": {
                "default": {},
                "type": "object",
                "patternProperties": {
                  "^(.*)$": {}
                }
              },
              "top": {
                "minimum": 1,
                "maximum": 50,
                "type": "integer"
              }
            }
          },
          "show": {
            "anyOf": [
              {
                "const": "always",
                "type": "string"
              },
              {
                "const": "on-match",
                "type": "string"
              },
              {
                "const": "manual",
                "type": "string"
              }
            ]
          },
          "collapsed": {
            "type": "boolean"
          },
          "top": {
            "minimum": 1,
            "maximum": 50,
            "description": "HUD shows top-K; workbench holds the rest",
            "type": "integer"
          },
          "use": {
            "additionalProperties": false,
            "type": "object",
            "properties": {
              "llm": {
                "type": "string"
              },
              "register": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "$id": "Action",
              "additionalProperties": false,
              "description": "the app prepares; verbs never send/commit/reply outward",
              "type": "object",
              "required": [
                "id",
                "label",
                "verb",
                "params"
              ],
              "properties": {
                "id": {
                  "minLength": 1,
                  "description": "opaque identifier",
                  "type": "string"
                },
                "label": {
                  "minLength": 1,
                  "maxLength": 24,
                  "type": "string"
                },
                "verb": {
                  "anyOf": [
                    {
                      "const": "copy",
                      "type": "string"
                    },
                    {
                      "const": "open",
                      "type": "string"
                    },
                    {
                      "const": "mark-done",
                      "type": "string"
                    },
                    {
                      "const": "dismiss",
                      "type": "string"
                    },
                    {
                      "const": "run-mode",
                      "type": "string"
                    },
                    {
                      "const": "draft-with",
                      "type": "string"
                    },
                    {
                      "const": "navigate",
                      "type": "string"
                    },
                    {
                      "const": "accept",
                      "type": "string"
                    },
                    {
                      "const": "pin",
                      "type": "string"
                    },
                    {
                      "const": "mark-for-follow-up",
                      "type": "string"
                    },
                    {
                      "const": "session-start",
                      "type": "string"
                    },
                    {
                      "const": "session-stop",
                      "type": "string"
                    }
                  ]
                },
                "params": {
                  "default": {},
                  "type": "object",
                  "patternProperties": {
                    "^(.*)$": {}
                  }
                }
              }
            }
          },
          "states": {
            "description": "micro-state dot vocabulary override: field-state key → dot tone. Absent ⇒ the shipped default vocab (provisional/confirmed/corrected). Lets a document re-vocabularize the dot per surface (e.g. approved/denied/tabled) without a code change.",
            "type": "array",
            "items": {
              "additionalProperties": false,
              "type": "object",
              "required": [
                "key",
                "tone"
              ],
              "properties": {
                "key": {
                  "minLength": 1,
                  "description": "the value a hydrated item carries in its `state` field",
                  "type": "string"
                },
                "tone": {
                  "minLength": 1,
                  "description": "the dot colour tone class (provisional | confirmed | corrected shipped; a custom key maps to any tone)",
                  "type": "string"
                }
              }
            }
          },
          "custom": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "htmlEndpoint"
            ],
            "properties": {
              "htmlEndpoint": {
                "description": "engine-served, sandboxed; API-only reach",
                "type": "string"
              }
            }
          },
          "input": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "target",
              "submit"
            ],
            "properties": {
              "target": {
                "minLength": 1,
                "description": "what the entry feeds — a free identifier (chat | entity-map | pins | …)",
                "type": "string"
              },
              "submit": {
                "minLength": 1,
                "description": "engine route the entry POSTs to, e.g. \"/chat\"; a failed submit surfaces as visible text",
                "type": "string"
              },
              "mode": {
                "description": "text-entry, file-drop, or both; absent ⇒ text",
                "anyOf": [
                  {
                    "const": "text",
                    "type": "string"
                  },
                  {
                    "const": "file",
                    "type": "string"
                  },
                  {
                    "const": "both",
                    "type": "string"
                  }
                ]
              },
              "placeholder": {
                "type": "string"
              },
              "submitLabel": {
                "description": "submit affordance label; absent ⇒ \"Send\"",
                "type": "string"
              },
              "accept": {
                "description": "file-drop accept filter (MIME/extension), e.g. \".pdf,.txt,.md\"; mode file/both only",
                "type": "string"
              }
            }
          }
        }
      }
    },
    "version": {
      "minimum": 1,
      "type": "integer"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "panel": {
      "$id": "AttachedPanel",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "edge",
        "collapsed",
        "expanded",
        "reveal"
      ],
      "properties": {
        "edge": {
          "description": "below ⇒ expand height; right ⇒ expand width",
          "anyOf": [
            {
              "const": "below",
              "type": "string"
            },
            {
              "const": "right",
              "type": "string"
            }
          ]
        },
        "collapsed": {
          "minimum": 0,
          "description": "window content size (px) along the edge axis when collapsed",
          "type": "integer"
        },
        "expanded": {
          "minimum": 1,
          "description": "window content size (px) along the edge axis when expanded",
          "type": "integer"
        },
        "reveal": {
          "description": "user = manual toggle only; event = also opens as a dismissible suggestion on a matching bus event",
          "anyOf": [
            {
              "const": "user",
              "type": "string"
            },
            {
              "const": "event",
              "type": "string"
            }
          ]
        },
        "openOn": {
          "minLength": 1,
          "description": "event name (or \"prefix.\" prefix) that SUGGESTS opening when reveal:\"event\"; matched tolerantly — an absent event is a no-op",
          "type": "string"
        },
        "startExpanded": {
          "description": "initial state; absent ⇒ collapsed",
          "type": "boolean"
        }
      }
    }
  }
}
