          "type": "string"
        },
        {
          "const": "pins",
          "type": "string"
        },
        {
          "const": "entities",
          "type": "string"
        },
        {
          "const": "todos",
          "type": "string"
        },
        {
          "const": "drafts",
          "type": "string"
        },
        {
          "const": "teach",
          "type": "string"
        },
        {
          "const": "distillates",
          "type": "string"
        }
      ]
    },
    "items": {
