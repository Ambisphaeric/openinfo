{
  "$id": "ChatTurn",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "role",
    "content"
  ],
  "properties": {
    "role": {
      "anyOf": [
        {
          "const": "user",
          "type": "string"
        },
        {
          "const": "assistant",
          "type": "string"
        }
      ]
    },
    "content": {
      "minLength": 1,
      "type": "string"
    },
    "contentClass": {
      "$id": "ContentClass",
      "description": "layer 4: content origin — screen denies hosted/public egress; transcript/typed may allow it",
      "anyOf": [
        {
          "const": "screen",
          "type": "string"
        },
        {
          "const": "transcript",
          "type": "string"
        },
        {
          "const": "typed",
          "type": "string"
        },
        {
          "const": "unknown",
          "type": "string"
        }
      ]
    }
  }
}
