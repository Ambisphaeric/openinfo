{
  "$id": "QueueStatus",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "pendingFiles",
    "pendingBytes",
    "drainedFiles",
    "updatedAt"
  ],
  "properties": {
    "pendingFiles": {
      "minimum": 0,
      "type": "integer"
    },
    "pendingBytes": {
      "minimum": 0,
      "type": "integer"
    },
    "drainedFiles": {
      "minimum": 0,
      "type": "integer"
    },
    "updatedAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "lastFailure": {
      "$id": "QueueFailure",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "class",
        "endpoint",
        "hint",
        "at"
      ],
      "properties": {
        "class": {
          "description": "the detected failure class — the difference the user asked the system to tell apart",
          "anyOf": [
            {
              "const": "unreachable",
              "type": "string"
            },
            {
              "const": "timeout",
              "type": "string"
            },
            {
              "const": "auth",
              "type": "string"
            },
            {
              "const": "model-load",
              "type": "string"
            },
            {
              "const": "bad-response",
              "type": "string"
            },
            {
              "const": "reasoning-exhausted",
              "type": "string"
            }
          ]
        },
        "endpoint": {
          "description": "the endpoint name the invoke failed on (never a secret value)",
          "type": "string"
        },
        "model": {
          "description": "the model that was asked for, when the endpoint names one",
          "type": "string"
        },
        "keyRef": {
          "description": "the auth keyRef involved on an auth failure — the REFERENCE, never the value",
          "type": "string"
        },
        "serverMessage": {
          "description": "the server's own error text (e.g. LM Studio's \"Model … failed to load\"), captured verbatim",
          "type": "string"
        },
        "hint": {
          "description": "the one-line \"what to do about it\" step",
          "type": "string"
        },
        "at": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        }
      }
    },
    "lastSuccessAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "shedFiles": {
      "minimum": 0,
      "type": "integer"
    },
    "byKind": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "audio",
        "screen",
        "llm-work"
      ],
      "properties": {
        "audio": {
          "$id": "QueueKindDepth",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "pendingChunks",
            "pendingBytes"
          ],
          "properties": {
            "pendingChunks": {
              "minimum": 0,
              "description": "spooled chunks of this kind not yet drained",
              "type": "integer"
            },
            "pendingBytes": {
              "minimum": 0,
              "description": "their on-disk JSONL bytes",
              "type": "integer"
            }
          }
        },
        "screen": {
          "$id": "QueueKindDepth",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "pendingChunks",
            "pendingBytes"
          ],
          "properties": {
            "pendingChunks": {
              "minimum": 0,
              "description": "spooled chunks of this kind not yet drained",
              "type": "integer"
            },
            "pendingBytes": {
              "minimum": 0,
              "description": "their on-disk JSONL bytes",
              "type": "integer"
            }
          }
        },
        "llm-work": {
          "$id": "QueueKindDepth",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "pendingChunks",
            "pendingBytes"
          ],
          "properties": {
            "pendingChunks": {
              "minimum": 0,
              "description": "spooled chunks of this kind not yet drained",
              "type": "integer"
            },
            "pendingBytes": {
              "minimum": 0,
              "description": "their on-disk JSONL bytes",
              "type": "integer"
            }
          }
        }
      }
    },
    "eta": {
      "$id": "BacklogEta",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "basis"
      ],
      "properties": {
        "basis": {
          "description": "observed = projected from recent drain durations; none = insufficient data, no fabricated ETA",
          "anyOf": [
            {
              "const": "observed",
              "type": "string"
            },
            {
              "const": "none",
              "type": "string"
            }
          ]
        },
        "etaMs": {
          "minimum": 0,
          "description": "projected ms until the backlog clears at the current drain rate (0 = already caught up)",
          "type": "number"
        },
        "caughtUpBy": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "drainRateChunksPerSec": {
          "minimum": 0,
          "description": "the observed drain rate the projection used",
          "type": "number"
        },
        "measuredTokPerSec": {
          "minimum": 0,
          "description": "the active llm endpoint's MEASURED tok/s (envelope §8) — context, not the ETA basis in v0",
          "type": "number"
        }
      }
    },
    "overflow": {
      "$id": "OverflowState",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "policy",
        "enforced"
      ],
      "properties": {
        "policy": {
          "description": "the declared overflow policy (from the active mode) when the mode exceeds measured hardware",
          "anyOf": [
            {
              "const": "queue-for-idle",
              "type": "string"
            },
            {
              "const": "degrade-cadence",
              "type": "string"
            },
            {
              "const": "drop",
              "type": "string"
            }
          ]
        },
        "enforced": {
          "description": "true only for queue-for-idle in v0 — degrade-cadence/drop are declared-but-inert (see PHASE4-NOTES)",
          "type": "boolean"
        }
      }
    }
  }
}
