{
  "$id": "PromptTemplate",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "name",
    "kind",
    "body"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "kind": {
      "description": "which pipeline stage this template feeds (extract = the extraction stage: typed moments AND entities, distinguished by template id; field = a fast-field prompt bound to a surface field, #61; preset = a workspace-selectable CONTEXT preset overlay prepended to the distill pass, editable over the same /templates routes — the glass \"five prompts\" made an actual document, pill P2; ask = the Ask face default question an empty send with a captured screen asks — a shipped document, not a hardcoded string, editable over the same /templates routes; summary = a hierarchical-summary prompt bound to a timescale level via `summary`, #177)",
      "anyOf": [
        {
          "const": "distill",
          "type": "string"
        },
        {
          "const": "extract",
          "type": "string"
        },
        {
          "const": "act",
          "type": "string"
        },
        {
          "const": "field",
          "type": "string"
        },
        {
          "const": "preset",
          "type": "string"
        },
        {
          "const": "ask",
          "type": "string"
        },
        {
          "const": "summary",
          "type": "string"
        }
      ]
    },
    "slot": {
      "description": "fabric capability slot",
      "anyOf": [
        {
          "const": "stt",
          "type": "string"
        },
        {
          "const": "tts",
          "type": "string"
        },
        {
          "const": "llm",
          "type": "string"
        },
        {
          "const": "vlm",
          "type": "string"
        },
        {
          "const": "ocr",
          "type": "string"
        },
        {
          "const": "embed",
          "type": "string"
        }
      ]
    },
    "body": {
      "minLength": 1,
      "description": "template with {{var}} placeholders",
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "builtin": {
      "type": "boolean"
    },
    "field": {
      "$id": "FastFieldBinding",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "fieldId",
        "tier",
        "trigger",
        "scope"
      ],
      "properties": {
        "fieldId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "tier": {
          "description": "model lane: fast runs event-driven on the small model; judge (#62) is the dual-input review pass on a larger model at a lower cadence",
          "anyOf": [
            {
              "const": "fast",
              "type": "string"
            },
            {
              "const": "judge",
              "type": "string"
            }
          ]
        },
        "trigger": {
          "additionalProperties": false,
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "description": "fire on newly transcribed material (the accumulation seam the distill cadence uses)",
              "const": "transcript",
              "type": "string"
            },
            "minChars": {
              "minimum": 0,
              "description": "the inexpensive relevance gate: skip the field when the new material is shorter than this",
              "type": "integer"
            }
          }
        },
        "scope": {
          "description": "where the field value lives: per live session, or across sessions for the workspace",
          "anyOf": [
            {
              "const": "session",
              "type": "string"
            },
            {
              "const": "workspace",
              "type": "string"
            }
          ]
        },
        "reviews": {
          "description": "judge tier only (#62): the fast fieldIds this judge reviews; absent ⇒ every fast field in scope",
          "type": "array",
          "items": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          }
        },
        "cadenceMs": {
          "minimum": 0,
          "description": "judge tier only (#62): minimum re-review interval, decoupled from the fast fan-out; absent ⇒ engine default",
          "type": "integer"
        },
        "produces": {
          "description": "judge tier only (#131): output shape — 'verdict' (default, #62 per-field review) or 'orientation' (session-nature classification landed as a SessionAnnotation)",
          "anyOf": [
            {
              "const": "verdict",
              "type": "string"
            },
            {
              "const": "orientation",
              "type": "string"
            }
          ]
        }
      }
    },
    "summary": {
      "$id": "SummaryBinding",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "level",
        "windowMs",
        "maxChildren"
      ],
      "properties": {
        "level": {
          "$id": "SummaryLevel",
          "description": "the summary timescale, finest (rolling) to coarsest (project)",
          "anyOf": [
            {
              "const": "rolling",
              "type": "string"
            },
            {
              "const": "episode",
              "type": "string"
            },
            {
              "const": "five-minute",
              "type": "string"
            },
            {
              "const": "session",
              "type": "string"
            },
            {
              "const": "project",
              "type": "string"
            }
          ]
        },
        "windowMs": {
          "minimum": 1,
          "description": "the interval this level buckets over (ignored for whole-session levels)",
          "type": "integer"
        },
        "childLevel": {
          "$id": "SummaryLevel",
          "description": "the summary timescale, finest (rolling) to coarsest (project)",
          "anyOf": [
            {
              "const": "rolling",
              "type": "string"
            },
            {
              "const": "episode",
              "type": "string"
            },
            {
              "const": "five-minute",
              "type": "string"
            },
            {
              "const": "session",
              "type": "string"
            },
            {
              "const": "project",
              "type": "string"
            }
          ]
        },
        "maxChildren": {
          "minimum": 1,
          "description": "HARD BOUND on lower-level inputs fed to the summarizer (newest kept)",
          "type": "integer"
        },
        "maxEvidence": {
          "minimum": 0,
          "description": "bound on selectively-retrieved evidence records; absent ⇒ none",
          "type": "integer"
        },
        "cadenceMs": {
          "minimum": 0,
          "description": "minimum re-summarize interval for the active window; absent ⇒ every pass",
          "type": "integer"
        },
        "scope": {
          "$id": "SummaryScope",
          "description": "the config scope a summary template binds to — workspace-global (default), or a specific workflow/app",
          "anyOf": [
            {
              "const": "workspace",
              "type": "string"
            },
            {
              "const": "workflow",
              "type": "string"
            },
            {
              "const": "app",
              "type": "string"
            }
          ]
        },
        "targetId": {
          "minLength": 1,
          "description": "the workflow/app id this binding is scoped to; absent ⇒ workspace-global",
          "type": "string"
        }
      }
    },
    "neverEgress": {
      "description": "#64 layer 2: true ⇒ this prompt never uses egress-capable endpoints",
      "type": "boolean"
    }
  }
}
