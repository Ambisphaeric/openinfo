{
  "$id": "Workspace",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "name",
    "dbFile",
    "createdAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "dbFile": {
      "description": "relative path of this workspace's OWN sqlite file",
      "pattern": "\\.db$",
      "type": "string"
    },
    "color": {
      "pattern": "^#[0-9a-fA-F]{6}$",
      "type": "string"
    },
    "retentionDays": {
      "minimum": 1,
      "description": "distillate retention; raw always deletes post-distill",
      "type": "integer"
    },
    "egress": {
      "$id": "EgressPolicy",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "deny"
      ],
      "properties": {
        "deny": {
          "description": "true ⇒ this mode/workspace denies egress wholesale",
          "type": "boolean"
        }
      }
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
