{
  "$id": "RelatedEntity",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "entityId",
    "name",
    "relations",
    "confidence",
    "claimIds"
  ],
  "properties": {
    "entityId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "relations": {
      "minItems": 1,
      "type": "array",
      "items": {
        "$id": "ClaimRelation",
        "description": "the relationship kind: co-occurs-with (symmetric; the only kind the slice-1 deterministic builder emits) · works-on/belongs-to/authored/member-of (directional semantic kinds — judge-enrichment slice + user corrections) · relates-to (generic fallback)",
        "anyOf": [
          {
            "const": "co-occurs-with",
            "type": "string"
          },
          {
            "const": "works-on",
            "type": "string"
          },
          {
            "const": "belongs-to",
            "type": "string"
          },
          {
            "const": "authored",
            "type": "string"
          },
          {
            "const": "member-of",
            "type": "string"
          },
          {
            "const": "relates-to",
            "type": "string"
          }
        ]
      }
    },
    "confidence": {
      "minimum": 0,
      "maximum": 1,
      "type": "number"
    },
    "claimIds": {
      "minItems": 1,
      "description": "live claims backing this link — each traceable to its evidence + scope",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    }
  }
}
