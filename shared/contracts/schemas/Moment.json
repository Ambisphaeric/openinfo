{
  "$id": "Moment",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "sessionId",
    "workspaceId",
    "at",
    "kind",
    "text",
    "refs",
    "source",
    "confidence"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "at": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "kind": {
      "description": "● commitment · ◆ question-at-you · ▲ decision · ✱ artifact · mention-of-user · note",
      "anyOf": [
        {
          "const": "commitment",
          "type": "string"
        },
        {
          "const": "question",
          "type": "string"
        },
        {
          "const": "decision",
          "type": "string"
        },
        {
          "const": "artifact",
          "type": "string"
        },
        {
          "const": "mention",
          "type": "string"
        },
        {
          "const": "note",
          "type": "string"
        }
      ]
    },
    "text": {
      "minLength": 1,
      "type": "string"
    },
    "speaker": {
      "description": "person entity id or raw label",
      "type": "string"
    },
    "refs": {
      "description": "entity ids referenced by this moment",
      "default": [],
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "source": {
      "anyOf": [
        {
          "const": "mic",
          "type": "string"
        },
        {
          "const": "screen",
          "type": "string"
        },
        {
          "const": "calendar",
          "type": "string"
        },
        {
          "const": "repo",
          "type": "string"
        },
        {
          "const": "camera",
          "type": "string"
        }
      ]
    },
    "confidence": {
      "minimum": 0,
      "maximum": 1,
      "type": "number"
    },
    "answered": {
      "description": "questions only: heard an answer yet?",
      "type": "boolean"
    }
  }
}
