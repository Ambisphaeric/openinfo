{
  "$id": "BuildSummariesRequest",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "workspaceId",
    "sessionId"
  ],
  "properties": {
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "level": {
      "description": "restrict production to one level; absent ⇒ every live-loop level (rolling → five-minute → session)",
      "anyOf": [
        {
          "const": "rolling",
          "type": "string"
        },
        {
          "const": "episode",
          "type": "string"
        },
        {
          "const": "five-minute",
          "type": "string"
        },
        {
          "const": "session",
          "type": "string"
        },
        {
          "const": "project",
          "type": "string"
        }
      ]
    }
  }
}
