{
  "$id": "GuardHold",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "workspaceId",
    "stage",
    "verdict",
    "status",
    "createdAt"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "stage": {
      "minLength": 1,
      "description": "the pipeline stage that was held (e.g. 'distill')",
      "type": "string"
    },
    "spanId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sourceChunks": {
      "description": "capture chunk ids of the held window — the parent link a trace walks; ids only, never content",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "target": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "endpoint"
      ],
      "properties": {
        "endpoint": {
          "minLength": 1,
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "destination": {
          "$id": "EgressDestination",
          "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
          "anyOf": [
            {
              "const": "device-local",
              "type": "string"
            },
            {
              "const": "lan-local",
              "type": "string"
            },
            {
              "const": "hosted-public",
              "type": "string"
            }
          ]
        },
        "delivery": {
          "description": "possible = transport failed after write may have begun; confirmed = an HTTP peer answered",
          "anyOf": [
            {
              "const": "possible",
              "type": "string"
            },
            {
              "const": "confirmed",
              "type": "string"
            }
          ]
        },
        "failureClass": {
          "minLength": 1,
          "description": "safe failure taxonomy label; never response body",
          "type": "string"
        }
      }
    },
    "consent": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "allowed",
        "decidedBy",
        "reason"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "decidedBy": {
          "$id": "EgressLayer",
          "description": "which of the four layers decided (or `default` = no denial, `endpoint` = destination-classification decided)",
          "anyOf": [
            {
              "const": "endpoint",
              "type": "string"
            },
            {
              "const": "prompt",
              "type": "string"
            },
            {
              "const": "mode",
              "type": "string"
            },
            {
              "const": "workspace",
              "type": "string"
            },
            {
              "const": "content-class",
              "type": "string"
            },
            {
              "const": "default",
              "type": "string"
            }
          ]
        },
        "reason": {
          "minLength": 1,
          "type": "string"
        }
      }
    },
    "classifierDestination": {
      "$id": "EgressDestination",
      "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
      "anyOf": [
        {
          "const": "device-local",
          "type": "string"
        },
        {
          "const": "lan-local",
          "type": "string"
        },
        {
          "const": "hosted-public",
          "type": "string"
        }
      ]
    },
    "verdict": {
      "$id": "GuardVerdict",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "outcome",
        "behavior",
        "guarded",
        "maskedSpanCount",
        "reason"
      ],
      "properties": {
        "outcome": {
          "description": "clean = guard ran, nothing flagged; redacted = flagged spans masked, hop proceeded; held = hop suspended (strict, or fail-closed empty slot); unguarded = no guard active, proceeded under explicit acknowledgment",
          "anyOf": [
            {
              "const": "clean",
              "type": "string"
            },
            {
              "const": "redacted",
              "type": "string"
            },
            {
              "const": "held",
              "type": "string"
            },
            {
              "const": "unguarded",
              "type": "string"
            }
          ]
        },
        "behavior": {
          "$id": "GuardBehavior",
          "description": "redact-and-continue (default, mask spans + proceed) | hold-and-surface (strict, suspend the hop)",
          "anyOf": [
            {
              "const": "redact-and-continue",
              "type": "string"
            },
            {
              "const": "hold-and-surface",
              "type": "string"
            }
          ]
        },
        "guarded": {
          "description": "true ⇒ a guard endpoint classified the content; false ⇒ no guard ran (acknowledged-unguarded or fail-closed-empty)",
          "type": "boolean"
        },
        "maskedSpanCount": {
          "minimum": 0,
          "description": "how many spans were masked (0 for clean/held/unguarded)",
          "type": "integer"
        },
        "spans": {
          "description": "span descriptors (kind/start/length) — never the raw value; present when spans were flagged",
          "type": "array",
          "items": {
            "$id": "GuardSpan",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "kind",
              "start",
              "length"
            ],
            "properties": {
              "kind": {
                "minLength": 1,
                "description": "the classifier label for this span (e.g. card-number) — a category, never the value",
                "type": "string"
              },
              "start": {
                "minimum": 0,
                "description": "character offset of the span in the outbound text",
                "type": "integer"
              },
              "length": {
                "minimum": 1,
                "description": "character length of the masked span (extent only — never the value)",
                "type": "integer"
              }
            }
          }
        },
        "guardEndpoint": {
          "description": "the guard endpoint NAME that classified — never a url/secret; absent when no guard ran",
          "type": "string"
        },
        "classifierDestination": {
          "$id": "EgressDestination",
          "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
          "anyOf": [
            {
              "const": "device-local",
              "type": "string"
            },
            {
              "const": "lan-local",
              "type": "string"
            },
            {
              "const": "hosted-public",
              "type": "string"
            }
          ]
        },
        "reason": {
          "minLength": 1,
          "description": "one-line, human-readable why — safe to surface (no raw value)",
          "type": "string"
        }
      }
    },
    "status": {
      "$id": "GuardHoldStatus",
      "description": "held | released (approved, original attempt not rerun) | denied",
      "anyOf": [
        {
          "const": "held",
          "type": "string"
        },
        {
          "const": "released",
          "type": "string"
        },
        {
          "const": "denied",
          "type": "string"
        }
      ]
    },
    "createdAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "resolvedAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
