{
  "$id": "RelevantEntity",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "entity",
    "score",
    "moments"
  ],
  "properties": {
    "entity": {
      "$id": "Entity",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "workspaceId",
        "kind",
        "name",
        "aliases",
        "momentRefs",
        "outboundCount",
        "firstSeen",
        "lastSeen"
      ],
      "properties": {
        "id": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "workspaceId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "kind": {
          "anyOf": [
            {
              "const": "person",
              "type": "string"
            },
            {
              "const": "artifact",
              "type": "string"
            },
            {
              "const": "topic",
              "type": "string"
            }
          ]
        },
        "name": {
          "minLength": 1,
          "type": "string"
        },
        "aliases": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "canonicalOf": {
          "description": "entity ids merged into this one",
          "type": "array",
          "items": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          }
        },
        "pinId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "momentRefs": {
          "default": [],
          "type": "array",
          "items": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          }
        },
        "outboundCount": {
          "minimum": 0,
          "default": 0,
          "description": "times SENT to someone — strongest canon signal",
          "type": "integer"
        },
        "mentions": {
          "minimum": 0,
          "default": 0,
          "description": "windows/distillates that mentioned this entity — the frequency signal for recency×frequency ranking",
          "type": "integer"
        },
        "provenance": {
          "description": "per-window trail: which distillate/window/model mentioned this entity (noise is inspectable)",
          "type": "array",
          "items": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "slot",
              "endpoint"
            ],
            "properties": {
              "distillateId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "windowStart": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "windowEnd": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "slot": {
                "description": "fabric capability slot",
                "anyOf": [
                  {
                    "const": "stt",
                    "type": "string"
                  },
                  {
                    "const": "tts",
                    "type": "string"
                  },
                  {
                    "const": "llm",
                    "type": "string"
                  },
                  {
                    "const": "vlm",
                    "type": "string"
                  },
                  {
                    "const": "ocr",
                    "type": "string"
                  },
                  {
                    "const": "embed",
                    "type": "string"
                  }
                ]
              },
              "endpoint": {
                "minLength": 1,
                "description": "fabric endpoint name that produced this mention",
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "spanId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              }
            }
          }
        },
        "firstSeen": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "lastSeen": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "confidence": {
          "minimum": 0,
          "maximum": 1,
          "type": "number"
        },
        "state": {
          "description": "resolution/micro-state (#66/#73): a user override stamps `confirmed`; the resolver (#72) will stamp `provisional`/`confirmed`/`corrected`. Read by the #66 micro-state dot — absent ⇒ no dot (nothing pretends to be resolved). Document-configurable vocab per surface; never fabricated.",
          "type": "string"
        },
        "ambiguity": {
          "$id": "EntityAmbiguity",
          "additionalProperties": false,
          "type": "object",
          "properties": {
            "rivalId": {
              "minLength": 1,
              "description": "opaque identifier",
              "type": "string"
            },
            "rivalName": {
              "type": "string"
            },
            "margin": {
              "description": "score margin of this entity over the rival — small ⇒ genuinely ambiguous",
              "type": "number"
            },
            "note": {
              "type": "string"
            }
          }
        },
        "resolutions": {
          "description": "append-only per-mention resolution trail (#72): the scored resolver stamps score+band+components (+rival, if any) for every mention that resolved to (or created) this entity. Absent on records that predate the resolver.",
          "type": "array",
          "items": {
            "$id": "EntityResolution",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "at",
              "heard",
              "score",
              "band",
              "phoneticFuzzy",
              "corpusPrior",
              "crossSourceCorroboration",
              "personAffinity"
            ],
            "properties": {
              "at": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "heard": {
                "minLength": 1,
                "description": "the surface form (heard/extracted mention) this decision resolved",
                "type": "string"
              },
              "score": {
                "minimum": 0,
                "maximum": 1,
                "type": "number"
              },
              "band": {
                "description": "auto (≥ auto threshold, silent link) · provisional (reviewable link) · new (created a fresh provisional entity)",
                "anyOf": [
                  {
                    "const": "auto",
                    "type": "string"
                  },
                  {
                    "const": "provisional",
                    "type": "string"
                  },
                  {
                    "const": "new",
                    "type": "string"
                  }
                ]
              },
              "phoneticFuzzy": {
                "minimum": 0,
                "maximum": 1,
                "type": "number"
              },
              "corpusPrior": {
                "minimum": 0,
                "description": "establishment multiplier (sighting count × recency); neutral 1.0 for a fresh entity, only boosts",
                "type": "number"
              },
              "crossSourceCorroboration": {
                "minimum": 0,
                "description": "INPUT multiplier (#74 correlator) — defaults to neutral 1.0; no producer feeds it yet",
                "type": "number"
              },
              "personAffinity": {
                "minimum": 0,
                "description": "INPUT multiplier (speaker/participant adjacency in the entity graph) — defaults to neutral 1.0; no producer yet",
                "type": "number"
              },
              "rivalId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "rivalName": {
                "type": "string"
              },
              "rivalScore": {
                "minimum": 0,
                "maximum": 1,
                "type": "number"
              },
              "margin": {
                "description": "winner score minus rival score — small ⇒ ambiguous",
                "type": "number"
              },
              "ambiguous": {
                "description": "true ⇒ a plausible rival scored within Δ; a silent auto-link was downgraded to reviewable",
                "type": "boolean"
              },
              "override": {
                "description": "true ⇒ resolved by a sovereign user override (pinned surface form), bypassing the score",
                "type": "boolean"
              }
            }
          }
        },
        "heardAs": {
          "description": "source-/confidence-typed ASR variants that resolved to this entity (accumulates as evidence)",
          "type": "array",
          "items": {
            "$id": "HeardAs",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "text"
            ],
            "properties": {
              "text": {
                "minLength": 1,
                "description": "the surface form (ASR variant) that resolved to this entity",
                "type": "string"
              },
              "source": {
                "description": "fabric capability slot",
                "anyOf": [
                  {
                    "const": "stt",
                    "type": "string"
                  },
                  {
                    "const": "tts",
                    "type": "string"
                  },
                  {
                    "const": "llm",
                    "type": "string"
                  },
                  {
                    "const": "vlm",
                    "type": "string"
                  },
                  {
                    "const": "ocr",
                    "type": "string"
                  },
                  {
                    "const": "embed",
                    "type": "string"
                  }
                ]
              },
              "confidence": {
                "minimum": 0,
                "maximum": 1,
                "type": "number"
              },
              "at": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              }
            }
          }
        },
        "sightings": {
          "description": "typed, append-only evidence trail: heard/seen/calendar sightings with timestamps",
          "type": "array",
          "items": {
            "$id": "Sighting",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "via",
              "at"
            ],
            "properties": {
              "via": {
                "description": "the sense that produced this sighting: heard (ASR), seen (screen), or calendar",
                "anyOf": [
                  {
                    "const": "heard",
                    "type": "string"
                  },
                  {
                    "const": "seen",
                    "type": "string"
                  },
                  {
                    "const": "calendar",
                    "type": "string"
                  }
                ]
              },
              "at": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "distillateId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "detail": {
                "description": "optional human-readable note about the sighting (never a secret value)",
                "type": "string"
              }
            }
          }
        },
        "overrides": {
          "description": "user corrections as first-class, append-only data that outrank scores (sovereign)",
          "type": "array",
          "items": {
            "$id": "EntityOverride",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "at"
            ],
            "properties": {
              "at": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "by": {
                "description": "who made the correction — the user",
                "type": "string"
              },
              "pinnedName": {
                "description": "surface form pinned to this entity — future mentions of it resolve here",
                "type": "string"
              },
              "rejectedRivalId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "rejectedRivalName": {
                "type": "string"
              },
              "note": {
                "description": "the correction's rationale (never a secret value)",
                "type": "string"
              }
            }
          }
        },
        "external": {
          "$id": "EntityExternal",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "system",
            "ref"
          ],
          "properties": {
            "system": {
              "minLength": 1,
              "description": "external system name, e.g. github",
              "type": "string"
            },
            "ref": {
              "minLength": 1,
              "description": "opaque external identifier, e.g. owner/repo",
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          }
        }
      }
    },
    "score": {
      "minimum": 0,
      "description": "recency×frequency rank score at query time",
      "type": "number"
    },
    "moments": {
      "description": "recent moments referencing this entity — the inspectable join",
      "type": "array",
      "items": {
        "$id": "Moment",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "id",
          "sessionId",
          "workspaceId",
          "at",
          "kind",
          "text",
          "refs",
          "source",
          "confidence"
        ],
        "properties": {
          "id": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "sessionId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "workspaceId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "at": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "kind": {
            "description": "● commitment · ◆ question-at-you · ▲ decision · ✱ artifact · mention-of-user · note",
            "anyOf": [
              {
                "const": "commitment",
                "type": "string"
              },
              {
                "const": "question",
                "type": "string"
              },
              {
                "const": "decision",
                "type": "string"
              },
              {
                "const": "artifact",
                "type": "string"
              },
              {
                "const": "mention",
                "type": "string"
              },
              {
                "const": "note",
                "type": "string"
              }
            ]
          },
          "text": {
            "minLength": 1,
            "type": "string"
          },
          "speaker": {
            "description": "person entity id or raw label",
            "type": "string"
          },
          "refs": {
            "description": "entity ids referenced by this moment",
            "default": [],
            "type": "array",
            "items": {
              "minLength": 1,
              "description": "opaque identifier",
              "type": "string"
            }
          },
          "source": {
            "anyOf": [
              {
                "const": "mic",
                "type": "string"
              },
              {
                "const": "screen",
                "type": "string"
              },
              {
                "const": "calendar",
                "type": "string"
              },
              {
                "const": "repo",
                "type": "string"
              },
              {
                "const": "camera",
                "type": "string"
              },
              {
                "const": "system-audio",
                "type": "string"
              }
            ]
          },
          "confidence": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "answered": {
            "description": "questions only: heard an answer yet?",
            "type": "boolean"
          },
          "provenance": {
            "additionalProperties": false,
            "type": "object",
            "required": [
              "slot",
              "endpoint"
            ],
            "properties": {
              "distillateId": {
                "minLength": 1,
                "description": "opaque identifier",
                "type": "string"
              },
              "windowStart": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "windowEnd": {
                "format": "date-time",
                "description": "ISO-8601 timestamp",
                "type": "string"
              },
              "slot": {
                "description": "fabric capability slot",
                "anyOf": [
                  {
                    "const": "stt",
                    "type": "string"
                  },
                  {
                    "const": "tts",
                    "type": "string"
                  },
                  {
                    "const": "llm",
                    "type": "string"
                  },
                  {
                    "const": "vlm",
                    "type": "string"
                  },
                  {
                    "const": "ocr",
                    "type": "string"
                  },
                  {
                    "const": "embed",
                    "type": "string"
                  }
                ]
              },
              "endpoint": {
                "minLength": 1,
                "description": "fabric endpoint name that produced this",
                "type": "string"
              },
              "model": {
                "type": "string"
              }
            }
          },
          "spanId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          }
        }
      }
    }
  }
}
