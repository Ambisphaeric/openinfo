{
  "$id": "Entity",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "workspaceId",
    "kind",
    "name",
    "aliases",
    "momentRefs",
    "outboundCount",
    "firstSeen",
    "lastSeen"
  ],
  "properties": {
    "id": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "kind": {
      "anyOf": [
        {
          "const": "person",
          "type": "string"
        },
        {
          "const": "artifact",
          "type": "string"
        },
        {
          "const": "topic",
          "type": "string"
        }
      ]
    },
    "name": {
      "minLength": 1,
      "type": "string"
    },
    "aliases": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonicalOf": {
      "description": "entity ids merged into this one",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "pinId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "momentRefs": {
      "default": [],
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "outboundCount": {
      "minimum": 0,
      "default": 0,
      "description": "times SENT to someone — strongest canon signal",
      "type": "integer"
    },
    "mentions": {
      "minimum": 0,
      "default": 0,
      "description": "windows/distillates that mentioned this entity — the frequency signal for recency×frequency ranking",
      "type": "integer"
    },
    "provenance": {
      "description": "per-window trail: which distillate/window/model mentioned this entity (noise is inspectable)",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "type": "object",
        "required": [
          "slot",
          "endpoint"
        ],
        "properties": {
          "distillateId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "windowStart": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "windowEnd": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "slot": {
            "description": "fabric capability slot",
            "anyOf": [
              {
                "const": "stt",
                "type": "string"
              },
              {
                "const": "tts",
                "type": "string"
              },
              {
                "const": "llm",
                "type": "string"
              },
              {
                "const": "vlm",
                "type": "string"
              },
              {
                "const": "ocr",
                "type": "string"
              },
              {
                "const": "embed",
                "type": "string"
              }
            ]
          },
          "endpoint": {
            "minLength": 1,
            "description": "fabric endpoint name that produced this mention",
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "usage": {
            "$id": "InvokeUsage",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "estimated"
            ],
            "properties": {
              "promptTokens": {
                "minimum": 0,
                "description": "input tokens (prompt), when known",
                "type": "integer"
              },
              "completionTokens": {
                "minimum": 0,
                "description": "output tokens (generated), when known",
                "type": "integer"
              },
              "totalTokens": {
                "minimum": 0,
                "description": "prompt + completion, when the server reports it or both halves are known",
                "type": "integer"
              },
              "estimated": {
                "description": "true ⇒ counts are chars/4 estimates (the server reported no usage); false ⇒ measured from the API",
                "type": "boolean"
              },
              "durationMs": {
                "minimum": 0,
                "description": "wall-clock duration of the invoke in ms",
                "type": "integer"
              }
            }
          },
          "egress": {
            "$id": "EgressDecision",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "reach",
              "allowed",
              "decidedBy",
              "reason"
            ],
            "properties": {
              "reach": {
                "$id": "EgressReach",
                "description": "layer 1 compatibility bucket: local-network (device loopback/managed or private LAN) vs hosted/public egress; use EgressDecision.destination for physical boundary truth",
                "anyOf": [
                  {
                    "const": "local",
                    "type": "string"
                  },
                  {
                    "const": "egress",
                    "type": "string"
                  }
                ]
              },
              "allowed": {
                "description": "did the layered content-side policy permit hosted/public egress for this content?",
                "type": "boolean"
              },
              "decidedBy": {
                "$id": "EgressLayer",
                "description": "which of the four layers decided (or `default` = no denial, `endpoint` = destination-classification decided)",
                "anyOf": [
                  {
                    "const": "endpoint",
                    "type": "string"
                  },
                  {
                    "const": "prompt",
                    "type": "string"
                  },
                  {
                    "const": "mode",
                    "type": "string"
                  },
                  {
                    "const": "workspace",
                    "type": "string"
                  },
                  {
                    "const": "content-class",
                    "type": "string"
                  },
                  {
                    "const": "default",
                    "type": "string"
                  }
                ]
              },
              "reason": {
                "minLength": 1,
                "description": "one-line, human-readable why — safe to surface (no url/secret)",
                "type": "string"
              },
              "destination": {
                "$id": "EgressDestination",
                "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
                "anyOf": [
                  {
                    "const": "device-local",
                    "type": "string"
                  },
                  {
                    "const": "lan-local",
                    "type": "string"
                  },
                  {
                    "const": "hosted-public",
                    "type": "string"
                  }
                ]
              },
              "rawFrameTrust": {
                "description": "present only when raw screen bytes crossed to a LAN-local HTTP endpoint under that endpoint’s explicit trustRawFrames opt-in",
                "const": "explicit",
                "type": "string"
              }
            }
          },
          "guard": {
            "$id": "GuardVerdict",
            "additionalProperties": false,
            "type": "object",
            "required": [
              "outcome",
              "behavior",
              "guarded",
              "maskedSpanCount",
              "reason"
            ],
            "properties": {
              "outcome": {
                "description": "clean = guard ran, nothing flagged; redacted = flagged spans masked, hop proceeded; held = hop suspended (strict, or fail-closed empty slot); unguarded = no guard active, proceeded under explicit acknowledgment",
                "anyOf": [
                  {
                    "const": "clean",
                    "type": "string"
                  },
                  {
                    "const": "redacted",
                    "type": "string"
                  },
                  {
                    "const": "held",
                    "type": "string"
                  },
                  {
                    "const": "unguarded",
                    "type": "string"
                  }
                ]
              },
              "behavior": {
                "$id": "GuardBehavior",
                "description": "redact-and-continue (default, mask spans + proceed) | hold-and-surface (strict, suspend the hop)",
                "anyOf": [
                  {
                    "const": "redact-and-continue",
                    "type": "string"
                  },
                  {
                    "const": "hold-and-surface",
                    "type": "string"
                  }
                ]
              },
              "guarded": {
                "description": "true ⇒ a guard endpoint classified the content; false ⇒ no guard ran (acknowledged-unguarded or fail-closed-empty)",
                "type": "boolean"
              },
              "maskedSpanCount": {
                "minimum": 0,
                "description": "how many spans were masked (0 for clean/held/unguarded)",
                "type": "integer"
              },
              "spans": {
                "description": "span descriptors (kind/start/length) — never the raw value; present when spans were flagged",
                "type": "array",
                "items": {
                  "$id": "GuardSpan",
                  "additionalProperties": false,
                  "type": "object",
                  "required": [
                    "kind",
                    "start",
                    "length"
                  ],
                  "properties": {
                    "kind": {
                      "minLength": 1,
                      "description": "the classifier label for this span (e.g. card-number) — a category, never the value",
                      "type": "string"
                    },
                    "start": {
                      "minimum": 0,
                      "description": "character offset of the span in the outbound text",
                      "type": "integer"
                    },
                    "length": {
                      "minimum": 1,
                      "description": "character length of the masked span (extent only — never the value)",
                      "type": "integer"
                    }
                  }
                }
              },
              "guardEndpoint": {
                "description": "the guard endpoint NAME that classified — never a url/secret; absent when no guard ran",
                "type": "string"
              },
              "classifierDestination": {
                "$id": "EgressDestination",
                "description": "physical destination of a completed invoke: device-local (managed/loopback), lan-local (device boundary crossed within the private network), or hosted-public",
                "anyOf": [
                  {
                    "const": "device-local",
                    "type": "string"
                  },
                  {
                    "const": "lan-local",
                    "type": "string"
                  },
                  {
                    "const": "hosted-public",
                    "type": "string"
                  }
                ]
              },
              "reason": {
                "minLength": 1,
                "description": "one-line, human-readable why — safe to surface (no raw value)",
                "type": "string"
              }
            }
          },
          "spanId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          }
        }
      }
    },
    "firstSeen": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "lastSeen": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "confidence": {
      "minimum": 0,
      "maximum": 1,
      "type": "number"
    },
    "state": {
      "description": "resolution/micro-state (#66/#73): a user override stamps `confirmed`; the resolver (#72) will stamp `provisional`/`confirmed`/`corrected`. Read by the #66 micro-state dot — absent ⇒ no dot (nothing pretends to be resolved). Document-configurable vocab per surface; never fabricated.",
      "type": "string"
    },
    "ambiguity": {
      "$id": "EntityAmbiguity",
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "rivalId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "rivalName": {
          "type": "string"
        },
        "margin": {
          "description": "score margin of this entity over the rival — small ⇒ genuinely ambiguous",
          "type": "number"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "resolutions": {
      "description": "append-only per-mention resolution trail (#72): the scored resolver stamps score+band+components (+rival, if any) for every mention that resolved to (or created) this entity. Absent on records that predate the resolver.",
      "type": "array",
      "items": {
        "$id": "EntityResolution",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "at",
          "heard",
          "score",
          "band",
          "phoneticFuzzy",
          "corpusPrior",
          "crossSourceCorroboration",
          "personAffinity"
        ],
        "properties": {
          "at": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "heard": {
            "minLength": 1,
            "description": "the surface form (heard/extracted mention) this decision resolved",
            "type": "string"
          },
          "score": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "band": {
            "description": "auto (≥ auto threshold, silent link) · provisional (reviewable link) · new (created a fresh provisional entity)",
            "anyOf": [
              {
                "const": "auto",
                "type": "string"
              },
              {
                "const": "provisional",
                "type": "string"
              },
              {
                "const": "new",
                "type": "string"
              }
            ]
          },
          "phoneticFuzzy": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "corpusPrior": {
            "minimum": 0,
            "description": "establishment multiplier (sighting count × recency); neutral 1.0 for a fresh entity, only boosts",
            "type": "number"
          },
          "crossSourceCorroboration": {
            "minimum": 0,
            "description": "INPUT multiplier (#74 correlator) — defaults to neutral 1.0; no producer feeds it yet",
            "type": "number"
          },
          "personAffinity": {
            "minimum": 0,
            "description": "INPUT multiplier (speaker/participant adjacency in the entity graph) — defaults to neutral 1.0; no producer yet",
            "type": "number"
          },
          "rivalId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "rivalName": {
            "type": "string"
          },
          "rivalScore": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "margin": {
            "description": "winner score minus rival score — small ⇒ ambiguous",
            "type": "number"
          },
          "ambiguous": {
            "description": "true ⇒ a plausible rival scored within Δ; a silent auto-link was downgraded to reviewable",
            "type": "boolean"
          },
          "override": {
            "description": "true ⇒ resolved by a sovereign user override (pinned surface form), bypassing the score",
            "type": "boolean"
          }
        }
      }
    },
    "heardAs": {
      "description": "source-/confidence-typed ASR variants that resolved to this entity (accumulates as evidence)",
      "type": "array",
      "items": {
        "$id": "HeardAs",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "minLength": 1,
            "description": "the surface form (ASR variant) that resolved to this entity",
            "type": "string"
          },
          "source": {
            "description": "fabric capability slot",
            "anyOf": [
              {
                "const": "stt",
                "type": "string"
              },
              {
                "const": "tts",
                "type": "string"
              },
              {
                "const": "llm",
                "type": "string"
              },
              {
                "const": "vlm",
                "type": "string"
              },
              {
                "const": "ocr",
                "type": "string"
              },
              {
                "const": "embed",
                "type": "string"
              }
            ]
          },
          "confidence": {
            "minimum": 0,
            "maximum": 1,
            "type": "number"
          },
          "at": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          }
        }
      }
    },
    "sightings": {
      "description": "typed, append-only evidence trail: heard/seen/calendar sightings with timestamps",
      "type": "array",
      "items": {
        "$id": "Sighting",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "via",
          "at"
        ],
        "properties": {
          "via": {
            "description": "the sense that produced this sighting: heard (ASR), seen (screen), or calendar",
            "anyOf": [
              {
                "const": "heard",
                "type": "string"
              },
              {
                "const": "seen",
                "type": "string"
              },
              {
                "const": "calendar",
                "type": "string"
              }
            ]
          },
          "at": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "distillateId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "detail": {
            "description": "optional human-readable note about the sighting (never a secret value)",
            "type": "string"
          }
        }
      }
    },
    "overrides": {
      "description": "user corrections as first-class, append-only data that outrank scores (sovereign)",
      "type": "array",
      "items": {
        "$id": "EntityOverride",
        "additionalProperties": false,
        "type": "object",
        "required": [
          "at"
        ],
        "properties": {
          "at": {
            "format": "date-time",
            "description": "ISO-8601 timestamp",
            "type": "string"
          },
          "by": {
            "description": "who made the correction — the user",
            "type": "string"
          },
          "pinnedName": {
            "description": "surface form pinned to this entity — future mentions of it resolve here",
            "type": "string"
          },
          "rejectedRivalId": {
            "minLength": 1,
            "description": "opaque identifier",
            "type": "string"
          },
          "rejectedRivalName": {
            "type": "string"
          },
          "note": {
            "description": "the correction's rationale (never a secret value)",
            "type": "string"
          }
        }
      }
    },
    "external": {
      "$id": "EntityExternal",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "system",
        "ref"
      ],
      "properties": {
        "system": {
          "minLength": 1,
          "description": "external system name, e.g. github",
          "type": "string"
        },
        "ref": {
          "minLength": 1,
          "description": "opaque external identifier, e.g. owner/repo",
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    }
  }
}
