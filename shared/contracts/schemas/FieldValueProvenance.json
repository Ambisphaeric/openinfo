{
  "$id": "FieldValueProvenance",
  "additionalProperties": false,
  "type": "object",
  "required": [
    "templateId",
    "slot",
    "endpoint"
  ],
  "properties": {
    "templateId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "slot": {
      "description": "fabric capability slot",
      "anyOf": [
        {
          "const": "stt",
          "type": "string"
        },
        {
          "const": "tts",
          "type": "string"
        },
        {
          "const": "llm",
          "type": "string"
        },
        {
          "const": "vlm",
          "type": "string"
        },
        {
          "const": "ocr",
          "type": "string"
        },
        {
          "const": "embed",
          "type": "string"
        }
      ]
    },
    "endpoint": {
      "description": "the fabric endpoint name that produced the value (never a secret value)",
      "type": "string"
    },
    "model": {
      "description": "the model that answered, when the endpoint names one",
      "type": "string"
    },
    "windowStart": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "windowEnd": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    },
    "sourceChunks": {
      "description": "capture chunk ids of the material window this value was drawn from",
      "type": "array",
      "items": {
        "minLength": 1,
        "description": "opaque identifier",
        "type": "string"
      }
    },
    "usage": {
      "$id": "InvokeUsage",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "estimated"
      ],
      "properties": {
        "promptTokens": {
          "minimum": 0,
          "description": "input tokens (prompt), when known",
          "type": "integer"
        },
        "completionTokens": {
          "minimum": 0,
          "description": "output tokens (generated), when known",
          "type": "integer"
        },
        "totalTokens": {
          "minimum": 0,
          "description": "prompt + completion, when the server reports it or both halves are known",
          "type": "integer"
        },
        "estimated": {
          "description": "true ⇒ counts are chars/4 estimates (the server reported no usage); false ⇒ measured from the API",
          "type": "boolean"
        },
        "durationMs": {
          "minimum": 0,
          "description": "wall-clock duration of the invoke in ms",
          "type": "integer"
        }
      }
    },
    "judge": {
      "$id": "JudgeReview",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "templateId",
        "endpoint",
        "verdict",
        "judgedAt"
      ],
      "properties": {
        "templateId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "endpoint": {
          "description": "the fabric endpoint name that judged (never a secret value)",
          "type": "string"
        },
        "model": {
          "description": "the judge model that answered, when the endpoint names one",
          "type": "string"
        },
        "verdict": {
          "description": "confirm: value stands; correct: value overruled in place (see priorValue); flag: questionable/too thin to judge",
          "anyOf": [
            {
              "const": "confirm",
              "type": "string"
            },
            {
              "const": "correct",
              "type": "string"
            },
            {
              "const": "flag",
              "type": "string"
            }
          ]
        },
        "priorValue": {
          "description": "the fast value the judge overruled — present on a `correct`, so \"what changed\" is inspectable",
          "type": "string"
        },
        "priorState": {
          "description": "the field state the review moved off of (e.g. provisional)",
          "type": "string"
        },
        "note": {
          "description": "the judge's rationale — the flag reason, or why a value was corrected",
          "type": "string"
        },
        "judgedAt": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        },
        "spanId": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "usage": {
          "$id": "InvokeUsage",
          "additionalProperties": false,
          "type": "object",
          "required": [
            "estimated"
          ],
          "properties": {
            "promptTokens": {
              "minimum": 0,
              "description": "input tokens (prompt), when known",
              "type": "integer"
            },
            "completionTokens": {
              "minimum": 0,
              "description": "output tokens (generated), when known",
              "type": "integer"
            },
            "totalTokens": {
              "minimum": 0,
              "description": "prompt + completion, when the server reports it or both halves are known",
              "type": "integer"
            },
            "estimated": {
              "description": "true ⇒ counts are chars/4 estimates (the server reported no usage); false ⇒ measured from the API",
              "type": "boolean"
            },
            "durationMs": {
              "minimum": 0,
              "description": "wall-clock duration of the invoke in ms",
              "type": "integer"
            }
          }
        }
      }
    }
  }
}
