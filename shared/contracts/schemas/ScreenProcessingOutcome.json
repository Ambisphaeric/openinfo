{
  "$id": "ScreenProcessingOutcome",
  "additionalProperties": false,
  "description": "metadata-only terminal result for one correlated screen frame",
  "type": "object",
  "required": [
    "workspaceId",
    "sessionId",
    "outcome",
    "capture",
    "completedAt"
  ],
  "properties": {
    "workspaceId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "sessionId": {
      "minLength": 1,
      "description": "opaque identifier",
      "type": "string"
    },
    "outcome": {
      "anyOf": [
        {
          "const": "processed",
          "type": "string"
        },
        {
          "const": "blank",
          "type": "string"
        },
        {
          "const": "failed",
          "type": "string"
        }
      ]
    },
    "capture": {
      "$id": "SenseLaneCapture",
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "capturedAt"
      ],
      "properties": {
        "id": {
          "minLength": 1,
          "description": "opaque identifier",
          "type": "string"
        },
        "capturedAt": {
          "format": "date-time",
          "description": "ISO-8601 timestamp",
          "type": "string"
        }
      }
    },
    "completedAt": {
      "format": "date-time",
      "description": "ISO-8601 timestamp",
      "type": "string"
    }
  }
}
