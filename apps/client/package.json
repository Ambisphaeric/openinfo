{
  "name": "@openinfo/client",
  "productName": "openinfo",
  "version": "0.0.19-pre.206",
  "type": "module",
  "main": "dist/main/shell.js",
  "scripts": {
    "build": "tsc -p .",
    "test": "node --test 'dist/**/*.test.js'",
    "test:e2e:hud": "pnpm build && electron scripts/hud-bounds-e2e.mjs",
    "test:e2e:panel": "pnpm build && electron scripts/panel-bounds-e2e.mjs",
    "test:e2e:chat": "pnpm build && electron scripts/chat-input-e2e.mjs",
    "test:e2e:clip": "pnpm build && electron scripts/clip-e2e.mjs",
    "test:e2e:multiwindow": "pnpm build && electron scripts/multiwindow-e2e.mjs",
    "test:e2e:capture": "pnpm build && electron scripts/capture-lifecycle-e2e.mjs",
    "test:e2e:attach": "pnpm build && electron scripts/attach-e2e.mjs",
    "test:e2e:ask": "pnpm build && electron scripts/ask-face-e2e.mjs",
    "test:e2e:askrace": "pnpm build && electron scripts/ask-race-e2e.mjs",
    "test:e2e:pill": "pnpm build && electron scripts/pill-e2e.mjs",
    "test:e2e:screen-surface": "pnpm --filter @openinfo/contracts build && pnpm --filter @openinfo/engine build && pnpm build && electron scripts/screen-surface-e2e.mjs",
    "test:e2e:vision-live": "pnpm build && electron scripts/vision-live-e2e.mjs",
    "start": "pnpm build && electron .",
    "package": "pnpm build && node scripts/package.mjs",
    "dmg": "pnpm build && node scripts/dmg.mjs"
  },
  "dependencies": {
    "@openinfo/contracts": "workspace:*"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@types/node": "^26.1.0",
    "electron": "^38.0.0",
    "typescript": "^6.0.3"
  }
}
